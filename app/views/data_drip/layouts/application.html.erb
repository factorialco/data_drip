<!DOCTYPE html>
<html class="h-full antialiased">
<head>
  <title>DataDrip</title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2032%2032'%3E%3Cpath%20fill='%23db2777'%20d='M16%203C10%2012%207%2016%207%2021a9%209%200%200018%200c0-5-3-9-9-18z'/%3E%3C/svg%3E">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%# Linked directly (not via stylesheet_link_tag) so the request never routes
      through the host asset pipeline. See DataDrip::AssetsController. %>
  <link rel="stylesheet" media="all" data-turbo-track="reload"
        href="<%= tailwind_stylesheet_path(v: DataDrip.compiled_css_digest) %>">
  <%= javascript_importmap_tags "application", importmap: DataDrip.importmap %>
  <%# No web fonts: the CSS falls back to the system sans stack (see --font-sans),
      keeping the admin UI self-contained and free of external requests. %>
</head>
<body
  class="min-h-dvh bg-white text-zinc-800 dark:bg-zinc-950 dark:text-zinc-300"
  data-controller="timezone"
  data-timezone-url-value="<%= set_timezone_backfill_runs_path %>"
  data-timezone-current-value="<%= session[:user_timezone] %>"
>
  <div class="isolate">
    <%= render "data_drip/shared/header" %>
    <main class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
      <%= render "data_drip/shared/flash" %>
      <%= yield %>
    </main>
  </div>
</body>
</html>
