<div class="min-h-screen flex bg-white">

  <%= render "data_drip/shared/sidebar", active: :catalog %>

  <div class="flex-1 flex flex-col items-center justify-start py-10">
    <div class="w-full max-w-5xl mb-8">
      <div
        class="
          bg-gradient-to-r from-slate-700 to-gray-900 rounded-lg p-6 shadow text-white
        "
      >
        <h1 class="text-2xl mb-1 text-left">Backfills Catalog</h1>
        <p class="text-sm font-light text-left mt-0.5">All datadrips available in this app, with their descriptions and the options they accept.</p>
      </div>
    </div>

    <div class="w-full max-w-5xl flex-1 flex flex-col">
      <div
        class="
          bg-white rounded-lg border border-gray-200 p-6 flex-1 flex flex-col
        "
      >
        <div class="mb-6">
          <input
            type="text"
            id="backfill_search"
            placeholder="Search by name, description, or field..."
            autocomplete="off"
            style="display: block; width: 100%; padding: 8px 12px 8px 34px;
                   border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px;
                   outline: none; box-sizing: border-box;
                   background-image: url(&quot;data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3E%3Cpath stroke='%239ca3af' stroke-linecap='round' stroke-width='2' d='m13 13 4 4M8.5 3a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11Z'/%3E%3C/svg%3E&quot;);
                   background-repeat: no-repeat; background-position: 10px center; background-size: 16px 16px;"
          />
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr>
                <th class="py-2 px-4 text-gray-400 font-semibold text-sm">NAME</th>
                <th class="py-2 px-4 text-gray-400 font-semibold text-sm">DESCRIPTION</th>
                <th class="py-2 px-4 text-gray-400 font-semibold text-sm">CUSTOM FIELDS</th>
              </tr>
            </thead>
            <tbody id="backfills_tbody">
              <% @backfills.each do |backfill| %>
                <tr class="border-b border-gray-100 last:border-b-0" data-search="<%= backfill_search_terms(backfill) %>">
                  <td class="py-3 px-4 text-gray-700 font-semibold align-middle" style="white-space: nowrap;"><%= backfill.name %></td>
                  <td class="py-3 px-4 text-gray-700" style="vertical-align: top;">
                    <% if backfill.description.present? %>
                      <%= backfill.description %>
                    <% else %>
                      <span style="color: #9ca3af;">No description</span>
                    <% end %>
                  </td>
                  <td class="py-3 px-4 text-gray-700" style="vertical-align: top;"><%= custom_field_tags(backfill) %></td>
                </tr>
              <% end %>
              <tr id="backfills_no_results" style="display: none;">
                <td colspan="3" class="py-3 px-4" style="text-align: center; color: #9ca3af; font-style: italic;">No matching backfills</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    var search = document.getElementById('backfill_search');
    if (!search) return;
    var rows = document.querySelectorAll('#backfills_tbody tr[data-search]');
    var noResults = document.getElementById('backfills_no_results');
    var debounceTimer;

    search.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      var input = this;
      debounceTimer = setTimeout(function() {
        var query = input.value.toLowerCase().trim();
        var visible = 0;
        rows.forEach(function(row) {
          var match = !query || row.getAttribute('data-search').indexOf(query) !== -1;
          row.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        noResults.style.display = visible === 0 ? '' : 'none';
      }, 150);
    });
  })();
</script>
