<% flash.each do |key, message| %>
  <% next if message.blank? %>
  <% notice = key.to_s == "notice" %>
  <div
    class="mb-6 flex items-start justify-between gap-x-4 rounded-lg p-4 <%= notice ? "bg-green-50 dark:bg-green-400/10" : "bg-red-50 dark:bg-red-400/10" %>"
    role="<%= notice ? "status" : "alert" %>"
    data-controller="flash"
  >
    <p class="text-sm <%= notice ? "text-green-800 dark:text-green-300" : "text-red-800 dark:text-red-300" %>"><%= message %></p>
    <button
      type="button"
      class="relative -m-1 rounded-md p-1 <%= notice ? "text-green-700 hover:bg-green-100 dark:text-green-300 dark:hover:bg-green-400/10" : "text-red-700 hover:bg-red-100 dark:text-red-300 dark:hover:bg-red-400/10" %>"
      aria-label="Dismiss"
      data-action="flash#dismiss"
    >
      <span class="pointer-fine:hidden absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-1/2" aria-hidden="true"></span>
      <svg viewBox="0 0 20 20" fill="currentColor" class="size-4" aria-hidden="true">
        <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
      </svg>
    </button>
  </div>
<% end %>
