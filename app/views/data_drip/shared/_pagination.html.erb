<% if pagination[:total_pages] > 1 %>
  <% additional_params ||= {} %>
  <nav class="mt-6 flex items-center justify-between gap-x-4" aria-label="Pagination">
    <p class="text-sm text-zinc-500 tabular-nums dark:text-zinc-400 max-sm:hidden">
      Showing <%= (pagination[:current_page] - 1) * pagination[:per_page] + 1 %>–<%= [pagination[:current_page] * pagination[:per_page], pagination[:total_count]].min %>
      of <%= pagination[:total_count] %> <%= item_name %>
    </p>

    <div class="flex items-center gap-x-1">
      <% if pagination[:has_previous_page] %>
        <%= link_to "Previous",
            url_for(additional_params.merge(page_param => pagination[:previous_page])),
            rel: "prev",
            class: secondary_button_classes(size: :small) %>
      <% else %>
        <span class="inline-flex items-center rounded-lg px-2.5 py-1 text-xs font-semibold text-zinc-300 dark:text-zinc-700" aria-disabled="true">Previous</span>
      <% end %>

      <% pagination[:page_range].each do |page_num| %>
        <% if page_num == pagination[:current_page] %>
          <span
            class="inline-flex min-w-7 items-center justify-center rounded-lg bg-drip-50 px-2 py-1 text-xs font-semibold text-drip-700 tabular-nums max-sm:hidden dark:bg-drip-400/10 dark:text-drip-300"
            aria-current="page"
          ><%= page_num %></span>
        <% else %>
          <%= link_to page_num,
              url_for(additional_params.merge(page_param => page_num)),
              class:
                "inline-flex min-w-7 items-center justify-center rounded-lg px-2 py-1 " \
                "text-xs font-medium text-zinc-600 tabular-nums hover:bg-zinc-950/5 " \
                "max-sm:hidden dark:text-zinc-400 dark:hover:bg-white/5" %>
        <% end %>
      <% end %>

      <% if pagination[:has_next_page] %>
        <%= link_to "Next",
            url_for(additional_params.merge(page_param => pagination[:next_page])),
            rel: "next",
            class: secondary_button_classes(size: :small) %>
      <% else %>
        <span class="inline-flex items-center rounded-lg px-2.5 py-1 text-xs font-semibold text-zinc-300 dark:text-zinc-700" aria-disabled="true">Next</span>
      <% end %>
    </div>
  </nav>
<% end %>
