<div
  data-controller="backfill-run-updates"
  data-backfill-run-updates-url-value="<%= updates_backfill_run_path(@backfill_run) %>"
  data-backfill-run-updates-status-value="<%= @backfill_run.status %>"
>
  <nav aria-label="Breadcrumb" class="flex items-center gap-x-2 text-sm">
    <%= link_to "Backfill runs", backfill_runs_path, class: "text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200" %>
    <span class="text-zinc-400 dark:text-zinc-600" aria-hidden="true">/</span>
    <span class="text-zinc-700 dark:text-zinc-300" aria-current="page">Run #<%= @backfill_run.id %></span>
  </nav>

  <div class="mt-4 flex flex-wrap items-center gap-3">
    <h1 class="text-xl font-semibold tracking-tight text-zinc-900 dark:text-white"><%= @backfill_run.backfill_class_name %></h1>
    <span data-backfill-run-updates-target="status"><%= status_tag(@backfill_run.status) %></span>

    <div class="flex flex-1 justify-end gap-x-2">
      <% if @backfill_run.running? %>
        <%= button_to "Stop run",
            stop_backfill_run_path(@backfill_run),
            method: :post,
            form: { data: { turbo_confirm: "Stop this backfill run? Batches that are already running will finish." } },
            class: danger_button_classes %>
      <% elsif @backfill_run.enqueued? %>
        <%= button_to "Delete run",
            backfill_run_path(@backfill_run),
            method: :delete,
            form: { data: { turbo_confirm: "Delete this backfill run?" } },
            class: danger_button_classes %>
      <% end %>
    </div>
  </div>
  <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
    Started by <%= @backfill_run.backfiller_name %>
    · created <%= relative_time(@backfill_run.created_at, @user_timezone) %>
  </p>

  <div class="mt-8 grid items-start gap-x-12 gap-y-8 lg:grid-cols-[3fr_2fr]">
    <div data-backfill-run-updates-target="progress">
      <%= render "progress", backfill_run: @backfill_run %>
    </div>

    <dl class="grid grid-cols-[auto_1fr] content-start gap-x-6 gap-y-2 text-sm">
      <dt class="text-zinc-500 dark:text-zinc-400">Batch size</dt>
      <dd class="font-medium text-zinc-900 tabular-nums dark:text-white"><%= number_with_delimiter(@backfill_run.batches.first&.batch_size || @backfill_run.batch_size) %></dd>

      <% if @backfill_run.amount_of_elements.present? %>
        <dt class="text-zinc-500 dark:text-zinc-400">Maximum records</dt>
        <dd class="font-medium text-zinc-900 tabular-nums dark:text-white"><%= number_with_delimiter(@backfill_run.amount_of_elements) %></dd>
      <% end %>

      <dt class="text-zinc-500 dark:text-zinc-400">Created</dt>
      <dd class="font-medium text-zinc-900 dark:text-white"><%= format_datetime_in_user_timezone(@backfill_run.created_at, @user_timezone) %></dd>

      <dt class="text-zinc-500 dark:text-zinc-400">Scheduled start</dt>
      <dd class="font-medium text-zinc-900 dark:text-white"><%= format_datetime_in_user_timezone(@backfill_run.start_at, @user_timezone) %></dd>

      <% if @backfill_run.options.present? %>
        <div class="col-span-full mt-2 rounded-lg bg-zinc-50 p-3 dark:bg-white/5">
          <p class="mb-1 font-mono text-xs font-medium text-zinc-400 dark:text-zinc-500">options</p>
          <% @backfill_run.options.each do |key, value| %>
            <p class="font-mono text-xs leading-6 text-zinc-600 dark:text-zinc-300"><%= key %> = <%= value.nil? ? "nil" : value %></p>
          <% end %>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="mt-12">
    <div class="flex flex-wrap items-center gap-3" data-backfill-run-updates-target="batchesMeta">
      <%= render "batches_meta", backfill_run: @backfill_run, batch_status: params[:batch_status] %>
    </div>

    <%# Render the (possibly empty) table while the run is active so the
        polling controller has a tbody to fill as batches appear. %>
    <% if @batches.any? || (!@backfill_run.terminal? && params[:batch_status].blank?) %>
      <div class="-mx-4 -my-2 mt-2 overflow-x-auto whitespace-nowrap sm:-mx-6 lg:-mx-8">
        <div class="inline-block min-w-full px-4 py-2 align-middle sm:px-6 lg:px-8">
          <table class="w-full text-left" data-controller="batch-errors">
            <thead>
              <tr>
                <th class="border-b border-zinc-950/10 py-2.5 pr-4 text-sm font-medium whitespace-nowrap text-zinc-500 dark:border-white/10 dark:text-zinc-400">Status</th>
                <th class="border-b border-zinc-950/10 py-2.5 pr-4 text-sm font-medium whitespace-nowrap text-zinc-500 dark:border-white/10 dark:text-zinc-400">Record range</th>
                <th class="border-b border-zinc-950/10 py-2.5 pr-4 text-sm font-medium whitespace-nowrap text-zinc-500 dark:border-white/10 dark:text-zinc-400">Size</th>
                <th class="border-b border-zinc-950/10 py-2.5 pr-4 text-sm font-medium whitespace-nowrap text-zinc-500 dark:border-white/10 dark:text-zinc-400">Finished</th>
                <th class="border-b border-zinc-950/10 py-2.5 text-sm font-medium whitespace-nowrap text-zinc-500 dark:border-white/10 dark:text-zinc-400">Error</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-950/5 dark:divide-white/5" data-backfill-run-updates-target="batchesTable">
              <%= render "batches_table", batches: @batches %>
            </tbody>
          </table>
        </div>
      </div>

      <%= render 'data_drip/shared/pagination',
          pagination: @batch_pagination,
          item_name: "batches",
          page_param: :batch_page,
          additional_params: { batch_status: params[:batch_status].presence }.compact %>
    <% else %>
      <div class="mt-2 border-t border-zinc-950/5 py-12 text-center dark:border-white/5">
        <p class="text-sm text-zinc-500 dark:text-zinc-400">
          <%= params[:batch_status] == "failed" ?
            "No failed batches." :
            "No batches yet — they are created when the run starts." %>
        </p>
      </div>
    <% end %>
  </div>
</div>
