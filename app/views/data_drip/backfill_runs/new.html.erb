
<div class="min-h-screen flex items-center justify-center m-8 bg-gradient-to-r from-slate-700 to-gray-900">
  <div class="w-full max-w-lg">
    <%= form_with model: @run, url: backfill_runs_path, local: true, html: { class: "bg-white p-10 md:p-14 rounded-lg", "data-turbo": "false" } do |f| %>
      <h1 class="text-4xl md:text-5xl font-semibold text-center mb-10 text-gray-700">New Backfill Run</h1>
      <% if @run.errors.any? %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
          <h4 class="font-bold mb-2">There were errors:</h4>
          <ul class="list-disc list-inside">
            <% @run.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-6">
        <%= f.label :backfill_class_name, "BACKFILL CLASS", class: "block text-gray-500 font-semibold mb-2" %>
        <div class="relative" id="backfill-class-combobox">
          <%# Hidden field carries the actual submitted value %>
          <%= f.hidden_field :backfill_class_name, id: "backfill_run_backfill_class_name" %>

          <%# Visible text input for searching %>
          <input
            type="text"
            id="backfill_class_search_input"
            placeholder="Search backfill class…"
            autocomplete="off"
            aria-haspopup="listbox"
            aria-expanded="false"
            aria-controls="backfill_class_listbox"
            class="block w-full mt-1 rounded border border-gray-200 focus:ring focus:ring-blue-200 focus:border-blue-400 px-3 py-2 pr-10"
          />
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-400" style="top: 4px;">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>

          <%# Dropdown list of options %>
          <ul
            id="backfill_class_listbox"
            role="listbox"
            aria-label="Backfill class options"
            class="absolute z-50 w-full bg-white border border-gray-200 rounded mt-1 max-h-60 overflow-y-auto shadow-lg hidden"
          >
            <% backfill_class_names.each do |name| %>
              <li
                role="option"
                aria-selected="false"
                data-value="<%= name %>"
                class="px-3 py-2 cursor-pointer hover:bg-blue-50 text-gray-700 text-sm"
              ><%= name %></li>
            <% end %>
            <li id="backfill_class_no_results" class="px-3 py-2 text-gray-400 text-sm italic hidden">No matches found</li>
          </ul>
        </div>
      </div>

      <div class="mb-6">
        <%= f.label :batch_size, "BATCH SIZE", class: "block text-gray-500 font-semibold mb-2" %>
        <%= f.number_field :batch_size, class: "block w-full mt-1 rounded border border-gray-200  focus:ring focus:ring-blue-200 focus:border-blue-400 px-3 py-2", min: 1 %>
      </div>

      <div class="mb-6">
        <%= f.label :amount_of_elements, "MAXIMUM AMOUNT OF ELEMENTS", class: "block text-gray-500 font-semibold mb-2" %>
        <%= f.number_field :amount_of_elements, class: "block w-full mt-1 rounded border border-gray-200  focus:ring focus:ring-blue-200 focus:border-blue-400 px-3 py-2", min: 0, step: 10 %>
      </div>

      <div id="backfill-options-container"></div>

      <div class="mb-6">
        <%= f.label :start_at, "RUN SHOULD START AT", class: "block text-gray-500 font-semibold mb-2" %>
        <%= f.datetime_field :start_at, value: "", class: "block w-full mt-1 rounded border border-gray-200 focus:ring focus:ring-blue-200 focus:border-blue-400 px-3 py-2" %>
      </div>
      <%= hidden_field_tag :user_timezone, "", id: "user_timezone" %>
      <div class="flex justify-center">
        <%= f.submit "Create Backfill Run", id: "submit-btn", class: "text-white font-bold py-2 px-4 rounded gradient-btn" %>
      </div>
    <% end %>
  </div>
</div>
<script>
  // ── Searchable backfill-class combobox ────────────────────────────────────
  (function () {
    function initCombobox() {
      var hiddenInput  = document.getElementById("backfill_run_backfill_class_name");
      var searchInput  = document.getElementById("backfill_class_search_input");
      var listbox      = document.getElementById("backfill_class_listbox");
      var noResults    = document.getElementById("backfill_class_no_results");

      if (!hiddenInput || !searchInput || !listbox) {
        setTimeout(initCombobox, 100);
        return;
      }

      var items = Array.from(listbox.querySelectorAll("li[data-value]"));
      var activeIndex = -1;

      function openList() {
        listbox.classList.remove("hidden");
        searchInput.setAttribute("aria-expanded", "true");
      }

      function closeList() {
        listbox.classList.add("hidden");
        searchInput.setAttribute("aria-expanded", "false");
        activeIndex = -1;
        items.forEach(function (li) { li.classList.remove("bg-blue-100"); });
      }

      function selectItem(li) {
        var value = li.getAttribute("data-value");
        hiddenInput.value = value;
        searchInput.value = value;
        li.setAttribute("aria-selected", "true");
        items.forEach(function (other) {
          if (other !== li) other.setAttribute("aria-selected", "false");
        });
        closeList();

        // Fire change event so handleBackfillClassChange still works
        var evt = new Event("change", { bubbles: true });
        hiddenInput.dispatchEvent(evt);
      }

      // ── Filtering ──────────────────────────────────────────────────────────
      var debounceTimer;
      searchInput.addEventListener("input", function () {
        clearTimeout(debounceTimer);
        var input = this;
        debounceTimer = setTimeout(function () {
          var query = input.value.toLowerCase().trim();
          var visible = 0;
          items.forEach(function (li) {
            // Support wildcards: * matches any sequence, ? matches one char
            var matches = query === "" || wildcardMatch(li.getAttribute("data-value").toLowerCase(), query);
            li.style.display = matches ? "" : "none";
            if (matches) visible++;
          });
          noResults.classList.toggle("hidden", visible > 0);
          activeIndex = -1;
          openList();
        }, 100);
      });

      // Flexible wildcard matching: * = any chars, ? = one char; falls back to
      // plain substring when no wildcards are present.
      function wildcardMatch(str, pattern) {
        if (pattern.indexOf("*") === -1 && pattern.indexOf("?") === -1) {
          return str.indexOf(pattern) !== -1;
        }
        var regexStr = pattern
          .replace(/[.+^${}()|[\]\\]/g, "\\$&") // escape regex specials
          .replace(/\*/g, ".*")
          .replace(/\?/g, ".");
        return new RegExp(regexStr).test(str);
      }

      // ── Show/hide on focus/blur ────────────────────────────────────────────
      searchInput.addEventListener("focus", function () {
        filterAndOpen("");
      });

      function filterAndOpen(query) {
        items.forEach(function (li) { li.style.display = ""; });
        noResults.classList.add("hidden");
        openList();
      }

      document.addEventListener("click", function (e) {
        if (!listbox.contains(e.target) && e.target !== searchInput) {
          closeList();
        }
      });

      // ── Option click ──────────────────────────────────────────────────────
      items.forEach(function (li) {
        li.addEventListener("mousedown", function (e) {
          e.preventDefault(); // prevent blur before click
          selectItem(li);
        });
      });

      // ── Keyboard navigation ───────────────────────────────────────────────
      searchInput.addEventListener("keydown", function (e) {
        var visibleItems = items.filter(function (li) { return li.style.display !== "none"; });
        if (e.key === "ArrowDown") {
          e.preventDefault();
          activeIndex = Math.min(activeIndex + 1, visibleItems.length - 1);
          highlightItem(visibleItems);
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          activeIndex = Math.max(activeIndex - 1, 0);
          highlightItem(visibleItems);
        } else if (e.key === "Enter") {
          e.preventDefault();
          if (activeIndex >= 0 && visibleItems[activeIndex]) {
            selectItem(visibleItems[activeIndex]);
          }
        } else if (e.key === "Escape") {
          closeList();
        }
      });

      function highlightItem(visibleItems) {
        items.forEach(function (li) { li.classList.remove("bg-blue-100"); });
        var target = visibleItems[activeIndex];
        if (target) {
          target.classList.add("bg-blue-100");
          target.scrollIntoView({ block: "nearest" });
        }
      }

      // Pre-fill display if there's an existing value (e.g. form re-render on error)
      if (hiddenInput.value) {
        searchInput.value = hiddenInput.value;
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initCombobox);
    } else {
      initCombobox();
    }
  })();

  // ── Backfill options fetch (unchanged logic) ──────────────────────────────
  function handleBackfillClassChange() {
    var selectedClass = this.value;
    var optionsContainer = document.getElementById("backfill-options-container");

    if (!optionsContainer) return;

    optionsContainer.innerHTML = "";

    if (selectedClass && selectedClass !== "Select a backfill class") {
      fetch("<%= backfill_options_backfill_runs_path %>?backfill_class_name=" + encodeURIComponent(selectedClass), {
        method: "GET",
        headers: {
          "Accept": "application/json",
          "X-Requested-With": "XMLHttpRequest",
          "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]')?.getAttribute('content')
        }
      })
      .then(function (response) {
        if (!response.ok) throw new Error("Network response was not ok: " + response.status);
        return response.json();
      })
      .then(function (data) {
        if (data.html) {
          optionsContainer.innerHTML = data.html;
          optionsContainer.querySelectorAll("script").forEach(function (oldScript) {
            var newScript = document.createElement("script");
            newScript.textContent = oldScript.textContent;
            oldScript.parentNode.replaceChild(newScript, oldScript);
          });
        }
      })
      .catch(function (error) {
        console.error("Error fetching backfill options:", error);
      });
    }
  }

  function initializeBackfillForm() {
    var timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone;
    var timeZoneInput = document.getElementById("user_timezone");
    if (timeZoneInput) {
      timeZoneInput.value = timeZone;
    }

    var hiddenInput = document.getElementById("backfill_run_backfill_class_name");
    var optionsContainer = document.getElementById("backfill-options-container");

    if (hiddenInput && optionsContainer) {
      hiddenInput.removeEventListener("change", handleBackfillClassChange);
      hiddenInput.addEventListener("change", handleBackfillClassChange);
    } else {
      setTimeout(initializeBackfillForm, 100);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeBackfillForm);
  } else {
    initializeBackfillForm();
  }

  document.addEventListener("DOMContentLoaded", function () {
    var form = document.querySelector('form[action*="backfill_runs"]');
    var submitBtn = document.getElementById("submit-btn");

    if (form && submitBtn) {
      form.addEventListener("submit", function () {
        submitBtn.disabled = true;
        submitBtn.textContent = "Creating...";
        submitBtn.classList.add("opacity-50", "cursor-not-allowed");
      });
    }
  });
</script>


